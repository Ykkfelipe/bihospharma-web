{
  "name": "bihospharma-new",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run chat:knowledge && next dev --turbopack",
    "build": "npm run chat:knowledge && next build",
    "chat:knowledge": "node scripts/build-chat-knowledge.mjs",
    "start": "NODE_ENV=production node server.js",
    "export": "next export",
    "lint": "next lint",
    "postbuild": "next-sitemap",
    "compress:images": "node scripts/compress-images.mjs",
    "refactor:sections": "node scripts/refactor-page-sections.mjs",
    "extract:pdf": "node scripts/extract-pdf.js \"BORRADOR WEB BHP (1).pdf\"",
    "prepare-deploy": "rm -rf deploy-ready && mkdir deploy-ready && cp -r public deploy-ready/ && cp -r .next deploy-ready/.next && cp package.json deploy-ready/ && cp server.js deploy-ready/ && zip -r bihospharma-deploy.zip deploy-ready",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "test:attendance": "npx tsx scripts/verify-attendance.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "canvas": "^3.1.2",
    "next": "15.5.2",
    "next-auth": "^5.0.0-beta.30",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^8.0.2",
    "pdfjs-dist": "^4.1.392",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-pdf": "^8.0.2",
    "react-slick": "^0.30.3",
    "signal-exit": "^4.1.0",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.2",
    "@types/react-slick": "^0.23.13",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.19.4",
    "typescript": "5.9.2"
  }
}
