// This is your Prisma schema file
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         String     @default("employee") // "admin" | "employee"
  createdAt    DateTime   @default(now())
  reactions    Reaction[]
  comments     Comment[]
  shifts       Shift[]
}

model Shift {
  id        String    @id @default(cuid())
  userId    String
  date      String    // "YYYY-MM-DD" for easy daily lookup
  checkIn   DateTime
  checkOut  DateTime?
  notes     String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Post {
  id        String     @id @default(cuid())
  title     String
  body      String?  // Optional text content
  fileUrl   String?  // Optional file path
  type      String   @default("announcement") // "announcement" | "document"
  createdAt DateTime @default(now())
  reactions Reaction[]
  comments  Comment[]
}

model Reaction {
  id        String   @id @default(cuid())
  type      String   // "like" | "love" | "clap" | "idea" | "check"
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}
